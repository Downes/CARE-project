# Copy to .env and fill in values before starting the container

# Port the Express server listens on (default: 3002)
PORT=3002

# Directory for SQLite database and Helia blockstore (default: /data in container)
DATA_DIR=/data

# CORS origin — set to your domain in production, or * to allow all
CLIENT_URL=https://care.mooc.ca

# kvstore authentication
# Internal URL of the kvstore container used to verify upload tokens.
# Change this if your kvstore runs elsewhere.
KVSTORE_URL=http://kvstore:5000

# IPFS network mode (optional)
# Set IPFS_ANNOUNCE_IP to your server's public IPv4 address to make this node
# a full participant in the public IPFS network. Leave unset for hermit mode
# (files stored locally only, accessible via /file/<cid> on this server).
# If set, you must also expose port 4001 in docker-compose.yml and open it
# in your firewall.
# IPFS_ANNOUNCE_IP=
# IPFS_PORT=4001
